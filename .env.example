# =============================================================================
# Gerätehaus.app – Beispiel-Umgebungskonfiguration
# =============================================================================
# Diese Datei enthält NUR technische/infrastrukturelle Werte.
# Fachliche Einstellungen (Organisationsname, Farben, Geofence, Module,
# Schwellenwerte usw.) werden NICHT hier konfiguriert, sondern beim ersten
# Start über den Setup-Wizard bzw. später im Moderator-Bereich der App.
#
# Kopiere diese Datei nach ".env" und passe die Werte an:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Datenbank (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=geratehaus
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=geratehaus
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Vollständige SQLAlchemy-Verbindungs-URL (wird i.d.R. aus den Werten oben
# zusammengesetzt, kann hier aber überschrieben werden)
# DATABASE_URL=postgresql+asyncpg://geratehaus:change-me-please@db:5432/geratehaus

# -----------------------------------------------------------------------------
# Sicherheit / JWT
# -----------------------------------------------------------------------------
# Geheimer Schlüssel zum Signieren der Moderator-JWTs. Mit z. B.
# `openssl rand -hex 32` erzeugen. NIEMALS den Default in Produktion nutzen!
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Geheimer Schlüssel zum Signieren der Mitglieder-Cookies (Name, PIN-Session)
COOKIE_SECRET_KEY=change-me-to-another-random-secret

# Fester initialer Admin-Benutzername für den Moderator-Login.
# Das zugehörige Passwort wird im Setup-Wizard festgelegt (nicht hier!).
ADMIN_USERNAME=admin

# -----------------------------------------------------------------------------
# Allgemein
# -----------------------------------------------------------------------------
# "production" oder "development"
ENVIRONMENT=production
# Öffentliche Basis-URL der App (für Links in Benachrichtigungen, Webhooks etc.)
PUBLIC_BASE_URL=https://geratehaus.example.org
# Erlaubte CORS-Origins, kommagetrennt (nur relevant falls Frontend separat gehostet wird;
# im Standard-Docker-Setup laufen Frontend und Backend über denselben Nginx-Origin,
# daher kann dies leer bleiben)
CORS_ORIGINS=
# Verzeichnis für hochgeladene Dateien (Logo etc.), als Docker-Volume mounten
UPLOAD_DIR=/app/uploads
# Host-Port, unter dem die App per docker-compose erreichbar ist (http://localhost:<PORT>)
HTTP_PORT=80

# Notifier (Telegram/E-Mail/Web Push) und Divera 24/7-Integration: jetzt unter
# Moderator > Einstellungen konfigurierbar, nicht mehr über die .env.
